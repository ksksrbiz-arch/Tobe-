# Production environment variables for the To Be Read site.
# Copy to `.env.local` for local dev. Set in the Netlify dashboard for prod.
# Server-only vars must NEVER be prefixed with NEXT_PUBLIC_.

# ── Netlify DB (Neon Postgres) ───────────────────────────────────────────────
# Auto-provisioned by Netlify when you enable Netlify DB on the project.
# Apply db/schema.sql once via the Neon SQL editor or:
#   psql "$NETLIFY_DATABASE_URL" -f db/schema.sql
NETLIFY_DATABASE_URL=

# ── NextAuth (auth.js) ───────────────────────────────────────────────────────
# Required. Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Resend (magic-link auth + wishlist hunt notifications) ───────────────────
# Both required. Sender must be a verified domain/identity in your Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@tobereadbooks.com

# ── Groq (Next Read Matchmaker LLM) ──────────────────────────────────────────
# Required for the matchmaker. Groq's free tier covers this workload. Get a key
# at https://console.groq.com/keys. Optionally override the model with
# GROQ_MODEL (defaults to llama-3.3-70b-versatile).
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
#
# Grounding uses the DuckDuckGo Instant Answer API, which is keyless and free —
# no env var required.

# ── Admin allowlist (server-only) ────────────────────────────────────────────
# Comma-separated emails that may sign in to /admin and POST /api/admin/shelve.
ADMIN_EMAILS=

# ── Optional: Google Books (lifts unauthenticated rate limit) ────────────────
GOOGLE_BOOKS_API_KEY=

# ── Optional: Google Places API for live reviews on /connect and /visit ──────
# Without these, the GoogleReviews component falls back to the rating + count
# from the Google Knowledge Panel and a deep-link to the Maps listing.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=

# ── Optional: Privacy-friendly analytics (Plausible, cookieless) ─────────────
# The <Analytics> component ships with the project's Plausible script committed
# as a default, so analytics works without any env config. Plausible counts
# only hits matching the domain registered in its dashboard, so preview and
# localhost traffic is ignored automatically.
#   NEXT_PUBLIC_PLAUSIBLE_SRC  override the script URL (e.g. a self-hosted
#                              Plausible instance). Set it to an empty value to
#                              disable analytics for a given deploy.
NEXT_PUBLIC_PLAUSIBLE_SRC=

# ── Optional: Customer reviews ───────────────────────────────────────────────
# Reviews submitted on /reviews are stored in the `reviews` table (see
# db/schema.sql) and held for staff moderation at /admin/reviews. The submitter
# IP is stored only as a salted SHA-256 hash for light abuse mitigation; set a
# private salt to make those hashes non-reversible across deploys. Falls back to
# a built-in default if unset.
REVIEW_IP_SALT=

# ── Optional: IndexNow (faster Bing/Yandex indexing) ─────────────────────────
# Submitted automatically on Netlify PRODUCTION deploys via the `postbuild`
# script; no-ops on previews/CI/local. The key is published at /<key>.txt and
# is NOT a secret. Only set this to rotate the key (and rename public/<key>.txt
# to match). Run `npm run indexnow` to submit manually.
INDEXNOW_KEY=
