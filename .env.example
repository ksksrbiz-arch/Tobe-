# Production environment variables for the To Be Read site.
# Copy to `.env.local` for local dev. Set in the Netlify dashboard for prod.
# Server-only vars must NEVER be prefixed with NEXT_PUBLIC_.

# ── Netlify DB (Neon Postgres) ───────────────────────────────────────────────
# Auto-provisioned by Netlify when you enable Netlify DB on the project.
# Apply db/schema.sql once via the Neon SQL editor or:
#   psql "$NETLIFY_DATABASE_URL" -f db/schema.sql
NETLIFY_DATABASE_URL=

# ── NextAuth (auth.js) ───────────────────────────────────────────────────────
# Required. Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Resend (magic-link auth + wishlist hunt notifications) ───────────────────
# Both required. Sender must be a verified domain/identity in your Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@tobereadbooks.com

# ── Google Gemini (Next Read Matchmaker) ─────────────────────────────────────
# Free tier covers the matchmaker workload. Get a key at
# https://aistudio.google.com/apikey. GOOGLE_API_KEY also accepted.
GEMINI_API_KEY=

# ── Admin allowlist (server-only) ────────────────────────────────────────────
# Comma-separated emails that may sign in to /admin and POST /api/admin/shelve.
ADMIN_EMAILS=

# ── Optional: Google Books (lifts unauthenticated rate limit) ────────────────
GOOGLE_BOOKS_API_KEY=

# ── Optional: Google Places API for live reviews on /connect and /visit ──────
# Without these, the GoogleReviews component falls back to the rating + count
# from the Google Knowledge Panel and a deep-link to the Maps listing.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=
